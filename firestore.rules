rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - photoURL: string
    //   - hasPaidEntry: boolean
    //   - credits: number
    //   - joinedAt: timestamp
    //
    // Collection: tournaments
    // Document ID: {tournamentId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - entryFee: number (required)
    //   - status: string (open, active, completed)
    //   - startTime: timestamp
    //
    // Collection: tournaments/{tournamentId}/entries
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required)
    //   - tournamentId: string (required)
    //   - paidAt: timestamp (required)
    //   - stripeSessionId: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "bradflick@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() < 128)) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 1024)) &&
             (!('hasPaidEntry' in data) || data.hasPaidEntry is bool) &&
             (!('joinedAt' in data) || (data.joinedAt is string && data.joinedAt.size() < 64));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid;
    }

    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();

      match /entries/{userId} {
        allow read: if isAuthenticated();
        allow create: if isAdmin(); // Created via webhook
        allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'userId', 'displayName']) &&
                      request.resource.data.score is number &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.displayName == resource.data.displayName;
        allow delete: if isAdmin();
      }
    }
  }
}
